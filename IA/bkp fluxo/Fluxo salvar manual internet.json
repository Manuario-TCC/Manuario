    {
      "parameters": {
        "jsCode": "// Percorre todos os itens que chegaram do nó anterior\nfor (const item of $input.all()) {\n  try {\n    // 1. Pega a string gerada pela IA (verifica se está em 'erro' ou 'output')\n    const textoDaIA = item.json.erro || item.json.output || \"\";\n\n    // 2. Transforma a string da IA em um objeto JSON real\n    const dadosConvertidos = JSON.parse(textoDaIA);\n\n    // 3. Cria as variáveis limpas na raiz do item\n    item.json.status = dadosConvertidos.status;\n    item.json.idioma = dadosConvertidos.idioma;\n    \n    // 4. Renomeia a variável do manual para ficar mais clara no resto do fluxo\n    item.json.manual_texto = item.json.text || \"\";\n\n    // 5. Limpeza de Segurança: Apaga os campos antigos para o JSON ficar leve e limpo\n    delete item.json.erro;\n    delete item.json.output;\n    delete item.json.text;\n\n  } catch (error) {\n    // BLINDAGEM: Se a IA falhar em gerar o JSON, o fluxo não quebra e mantém o manual salvo\n    item.json.status = \"ERRO\";\n    item.json.idioma = \"N/A\";\n    item.json.manual_texto = item.json.text || \"\";\n    item.json.erro_parse = \"A IA não retornou um JSON válido.\";\n  }\n}\n\n// Retorna os dados perfeitamente estruturados\nreturn $input.all();"
      },
