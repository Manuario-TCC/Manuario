    {
      "parameters": {
        "jsCode": "// 1. RECEBER O TEXTO DO MANUAL\nconst rawText = $input.first().json.manual_jogo || \"\";\n\nlet gameName = \"Jogo Desconhecido\";\ntry {\n  gameName = $('When chat message received').first().json.chatInput;\n} catch (error) {\n  gameName = \"Jogo Desconhecido\";\n}\n\n// 2. CONFIGURAÇÃO DE LIMITES\nconst MAX_CARACTERES = 1200; // Tamanho ideal por bloco\nconst MIN_CARACTERES_FINAL = 400; // Se a sobra final for menor que isso, anexa ao anterior\n\nconst tableData = [];\nconst lines = rawText.split('\\n');\n\nlet currentChunk = \"\";\nlet chunkIndex = 1;\n\n// 3. PROCESSAMENTO E FATIAMENTO\nfor (let i = 0; i < lines.length; i++) {\n  let line = lines[i].trim();\n  \n  if (!line) continue;\n  if (line.length <= 2 && !line.match(/[0-9]/)) continue;\n  if (line === \"TM\" || line === \"®\") continue;\n\n  if ((currentChunk.length + line.length) > MAX_CARACTERES) {\n    if (currentChunk.trim().length > 0) {\n      tableData.push({\n        \"Nome do Jogo\": gameName,\n        \"Nome da Regra\": `Fragmento ${chunkIndex}`,\n        \"Conteúdo da Regra\": currentChunk.trim(),\n        \"Palavras_Chave\": gameName\n      });\n      chunkIndex++;\n      currentChunk = \"\"; \n    }\n  }\n\n  currentChunk += line + \"\\n\";\n}\n\n// 4. TRATAMENTO INTELIGENTE DA SOBRA (O que resolve o seu problema)\nlet sobraFinal = currentChunk.trim();\n\nif (sobraFinal.length > 0) {\n  // Se a sobra for pequena E já existir um bloco anterior, costura no último bloco\n  if (sobraFinal.length < MIN_CARACTERES_FINAL && tableData.length > 0) {\n    let ultimoIndice = tableData.length - 1;\n    tableData[ultimoIndice][\"Conteúdo da Regra\"] += \"\\n\" + sobraFinal;\n  } else {\n    // Se a sobra for grande (ou se for o único texto do manual), cria o último bloco normalmente\n    tableData.push({\n      \"Nome do Jogo\": gameName,\n      \"Nome da Regra\": `Fragmento ${chunkIndex}`,\n      \"Conteúdo da Regra\": sobraFinal,\n      \"Palavras_Chave\": gameName\n    });\n  }\n}\n\n// Retorna os dados fragmentados para o n8n\nreturn tableData.map(row => ({ json: row }));"
      },
