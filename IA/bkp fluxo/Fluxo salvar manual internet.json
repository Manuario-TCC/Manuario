    {
      "parameters": {
        "jsCode": "// 1. Arraste a variável com o texto do PDF selecionando o texto \"ARRASTE_SEU_TEXTO_AQUI\"\nlet textoCompleto = $input.first().json.text; \n\n// Exemplo de como vai ficar depois que você arrastar:\n// let textoCompleto = $json[\"text\"]; ou $node[\"Extract from File\"].json[\"text\"];\n\n// 2. Define o limite de caracteres (4000 caracteres = aprox. 1000 tokens)\nconst MAX_CARACTERES = 1000;\n\n// 3. Prevenção de falhas (se o PDF for apenas imagem e vier vazio)\nif (!textoCompleto || typeof textoCompleto !== 'string' || textoCompleto.trim() === \"\") {\n  return {\n    json: {\n      texto_amostra: \"[ERRO] PDF vazio ou baseado em imagens (sem texto detectável).\"\n    }\n  };\n}\n\n// 4. Fatiamento: Pega do caractere 0 até o limite\nlet textoCortado = textoCompleto.substring(0, MAX_CARACTERES);\n\n// 5. Limpeza: Remove os buracos em branco enormes para economizar mais tokens\ntextoCortado = textoCortado.replace(/\\n{3,}/g, '\\n\\n').trim();\n\n// Se o manual for muito grande, adiciona o aviso no final\nif (textoCompleto.length > MAX_CARACTERES) {\n   textoCortado += \"\\n\\n[... TEXTO CORTADO PELO SISTEMA PARA ECONOMIA DE TOKENS ...]\";\n}\n\n// 6. Retorna o texto fatiado pronto para a IA ler\nreturn {\n  json: {\n    texto_amostra: textoCortado\n  }\n};"
      },
