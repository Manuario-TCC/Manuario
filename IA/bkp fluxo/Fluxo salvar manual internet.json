    {
      "parameters": {
        "jsCode": "// 1. Pega o JSON do nó anterior (Search Google / SerpApi)\nconst inputData = $input.all()[0].json;\n\n// 2. Acessa a lista de resultados da pesquisa\nconst organicResults = inputData.organic_results || [];\n\n// 3. Cria uma lista vazia para armazenar os links válidos\nconst pdfLinks = [];\n\n// 4. Varre todos os resultados procurando PDFs\nfor (const result of organicResults) {\n  if (result.link) {\n    // Converte o link para minúsculo para facilitar a verificação\n    const linkMinusculo = result.link.toLowerCase();\n    \n    // Usamos .includes('.pdf') em vez de .endsWith('.pdf') para garantir que\n    // links com parâmetros no final (ex: .pdf?id=123) não sejam descartados\n    if (linkMinusculo.includes('.pdf')) {\n      pdfLinks.push({\n        titulo: result.title || \"Documento sem título\",\n        url_download: result.link,\n        posicao_google: result.position\n      });\n    }\n  }\n}\n\n// 5. Tratamento de Falha (Se não achar nenhum PDF)\nif (pdfLinks.length === 0) {\n  return [{ json: { erro: \"Nenhum link de PDF encontrado na busca.\" } }];\n}\n\n// 6. Retorna a lista no formato padrão do n8n para o nó Loop\n// Cada link vira um \"Item\" separado no fluxo\nreturn pdfLinks.map(item => ({ json: item }));"
      },
