    {
      "parameters": {
        "jsCode": "// 1. Pega todos os itens que chegaram no nó\nconst items = $input.all();\n\n// Prevenção de erro: se a lista estiver vazia, encerra elegantemente\nif (items.length === 0) {\n  return [{ json: { manual_completo: \"Nenhuma regra encontrada.\" } }];\n}\n\n// 2. Extrai o nome do jogo (usamos o primeiro item da lista como referência)\nconst nomeJogo = items[0].json.nome_jogo;\n\n// 3. Monta o Sumário iterando sobre os títulos\nlet sumario = `## Sumário\\n\\n`;\nfor (const item of items) {\n  sumario += `* ${item.json.titulo_regra}\\n`;\n}\n\n// 4. Monta o Corpo do Manual com as descrições\nlet corpoRegras = `## Regras do Jogo\\n\\n`;\nfor (const item of items) {\n  // Adiciona o título da regra como cabeçalho (##)\n  corpoRegras += `## ${item.json.titulo_regra}\\n\\n`;\n  \n  // Adiciona o conteúdo detalhado gerado pela IA\n  corpoRegras += `${item.json.conteudo_regra}\\n\\n`;\n  \n  // Adiciona uma linha divisória do Markdown (---) para separar visualmente as regras\n  corpoRegras += `---\\n\\n`; \n}\n\n// 5. Junta todas as partes em uma única string de Markdown\nconst textoFinal = `# Manual de Regras: ${nomeJogo}\\n\\n${sumario}\\n${corpoRegras}`;\n\n// 6. Retorna um ÚNICO item contendo o manual completo consolidado\nreturn [{\n  json: {\n    nome_jogo: nomeJogo,\n    manual_completo: textoFinal\n  }\n}];"
      },
