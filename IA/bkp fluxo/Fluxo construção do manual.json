        "jsCode": "// O n8n passa os dados de entrada na variável 'items'\nconst inputData = $input.all()[0].json;\nconst rawText = inputData.text || \"\";\n\n// 1. NOME DO JOGO (Direto do Chat)\nlet gameName = \"Manual Desconhecido\";\n\ntry {\n  // Puxa exatamente o que o usuário digitou no chat\n  gameName = $('When chat message received').first().json.chatInput;\n} catch (error) {\n  // Plano B (Fallback): Caso você esteja testando o nó isoladamente\n  if (inputData.info && inputData.info.Title) {\n    gameName = inputData.info.Title.replace(/[^a-zA-Z0-9 ]/g, \" \").trim();\n  }\n}\n\nconst tableData = [];\nconst lines = rawText.split('\\n');\n\nlet currentRuleName = \"Introdução e Componentes\";\nlet currentRuleContent = [];\n\n// 2. FUNÇÃO INTELIGENTE (HEURÍSTICA) PARA DETECTAR TÍTULOS\nfunction isDynamicHeading(line) {\n  const hasLetters = /[a-zA-Z]/.test(line);\n  const validLength = line.length > 2 && line.length <= 60;\n  const isUpper = line === line.toUpperCase();\n  const noEndPunctuation = !/[.,;]$/.test(line.trim());\n  \n  return hasLetters && validLength && isUpper && noEndPunctuation;\n}\n\n// 3. PROCESSAMENTO DO TEXTO\nfor (let i = 0; i < lines.length; i++) {\n  let line = lines[i].trim();\n  \n  if (!line) continue;\n\n  if (line.length <= 2 && !line.match(/[0-9]/)) continue;\n  if (line === \"TM\" || line === \"®\") continue;\n\n  if (isDynamicHeading(line)) {\n    if (currentRuleContent.length > 0) {\n      tableData.push({\n        \"Nome do Jogo\": gameName,\n        \"Nome da Regra\": currentRuleName,\n        \"Conteúdo da Regra\": currentRuleContent.join('\\n'),\n        \"Palavras_Chave\": `${gameName}, ${currentRuleName}, manual, regras`\n      });\n    }\n    currentRuleName = line;\n    currentRuleContent = [];\n  } else {\n    currentRuleContent.push(line);\n  }\n}\n\n// 4. FINALIZAÇÃO\nif (currentRuleContent.length > 0) {\n  tableData.push({\n    \"Nome do Jogo\": gameName,\n    \"Nome da Regra\": currentRuleName,\n    \"Conteúdo da Regra\": currentRuleContent.join('\\n'),\n    \"Palavras_Chave\": `${gameName}, ${currentRuleName}, manual, regras`\n  });\n}\n\n// Retorna os dados fragmentados para o n8n\nreturn tableData.map(row => ({ json: row }));"
      },
