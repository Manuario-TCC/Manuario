    {
      "parameters": {
        "jsCode": "// ==========================================\n// 1. PEGA OS DADOS DIRETAMENTE DO NÓ ANTERIOR\n// ==========================================\nconst inputData = $input.first().json;\nconst listaJogos = inputData.jogos;\n\n// Verifica se a lista realmente tem dados\nif (!listaJogos || !Array.isArray(listaJogos) || listaJogos.length === 0) {\n  return [{ json: { prompt_jogos: \"Nenhum jogo encontrado.\" } }];\n}\n\n// ==========================================\n// 2. FORMATANDO O TEXTO PARA A IA (LLM)\n// ==========================================\n// Cria o cabeçalho do texto aproveitando o termo buscado\nlet textoParaIA = `Opções de jogos encontradas para \"${inputData.termo_buscado}\":\\n`;\n\n// Passa por cada jogo da lista e extrai só o nome e o ano\nlistaJogos.forEach((jogo, index) => {\n  // Pega o nome e o ano, com uma trava de segurança caso a API não tenha enviado o ano\n  const nomeJogo = jogo.name?.value || \"Nome não informado\";\n  const anoJogo = jogo.yearpublished?.value || \"Ano desconhecido\";\n  \n  // Monta a linha no formato: \"1. Nome do Jogo (Ano: 0000)\"\n  textoParaIA += `${index + 1}. ${nomeJogo} (Ano: ${anoJogo})\\n`;\n});\n\n// ==========================================\n// 3. RETORNO PARA O PRÓXIMO NÓ\n// ==========================================\nreturn [{ \n  json: { \n    // Retornamos o texto formatado limpo para jogar no Prompt do Agente\n    prompt_jogos: textoParaIA \n  } \n}];"
      },
