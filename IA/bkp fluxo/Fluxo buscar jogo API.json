    {
      "parameters": {
        "jsCode": "// 1. Pega o JSON do nó XML (ou API)\nconst inputData = $input.all()[0].json;\n\n// ==========================================\n// CONFIGURAÇÕES GERAIS\n// ==========================================\nconst limiteItens = 5; // Define a quantidade máxima de jogos que serão retornados\n\n// ==========================================\n// FUNÇÃO DE NORMALIZAÇÃO\n// Remove acentos e deixa TUDO MAIÚSCULO\n// ==========================================\nfunction normalizarTexto(texto) {\n  if (!texto) return \"\";\n  return texto\n    .toString()\n    .normalize('NFD') // Separa os caracteres dos acentos\n    .replace(/[\\u0300-\\u036f]/g, \"\") // Remove os acentos\n    .toUpperCase() // Deixa tudo maiúsculo\n    .trim();\n}\n\n// 2. Define o nome do jogo buscado pelo usuário\n// (Ajuste a referência do nó conforme seu fluxo)\nconst rawTargetName = $('Dados').first().json.Msg;\nconst targetName = normalizarTexto(rawTargetName);\n\n// 3. Garante que a lista de itens é um Array \nlet gamesList = inputData.items?.item;\n\nif (!gamesList) {\n  return [{ json: { erro: \"Nenhum jogo retornado pela API na busca.\" } }];\n}\nif (!Array.isArray(gamesList)) {\n  gamesList = [gamesList];\n}\n\n// 4. Listas para separar os níveis de correspondência\nconst matchesExatos = [];\nconst matchesPrioritarios = []; // Com espaço, ':' ou '-' (Ex: UNO FLIP, ORCS MUST DIE)\nconst matchesParciais = [];     // Letras no meio de outra palavra (Ex: UNORIGINAL, SORCERERS)\n\n// ==========================================\n// A BUSCA INTELIGENTE (COM FILTRO)\n// ==========================================\nfor (const game of gamesList) {\n  if (game && game.name && game.name.value) {\n    const gameNameFromAPI = normalizarTexto(game.name.value);\n\n    // PASSO A: Correspondência EXATA (\"UNO\" ou \"ORCS\")\n    if (gameNameFromAPI === targetName) {\n      matchesExatos.push(game);\n    } \n    // PASSO B: Correspondência com Espaço ou Pontuação logo após o termo\n    // Evita pegar \"Unoriginal\" quando a busca é \"UNO\"\n    else if (\n      gameNameFromAPI.includes(targetName + \" \") || \n      gameNameFromAPI.includes(targetName + \":\") ||\n      gameNameFromAPI.includes(targetName + \"-\")\n    ) {\n      matchesPrioritarios.push(game);\n    }\n    // PASSO C: Correspondência PARCIAL (O que sobrar)\n    else if (gameNameFromAPI.includes(targetName)) {\n      matchesParciais.push(game);\n    }\n  }\n}\n\n// ==========================================\n// FUNÇÃO DE ORDENAÇÃO POR ANO (Mais novo para o mais antigo)\n// ==========================================\nfunction ordenarPorAnoDecrescente(lista) {\n  return lista.sort((a, b) => {\n    // Pega o ano. Se não existir na API (undefined), assume 0 para ir pro final da lista\n    const anoA = parseInt(a.yearpublished?.value) || 0;\n    const anoB = parseInt(b.yearpublished?.value) || 0;\n    \n    return anoB - anoA; // A subtração invertida força a ordem do maior para o menor\n  });\n}\n\n// Ordena cada grupo de match individualmente para não quebrar o nível de prioridade\nordenarPorAnoDecrescente(matchesExatos);\nordenarPorAnoDecrescente(matchesPrioritarios);\nordenarPorAnoDecrescente(matchesParciais);\n\n// ==========================================\n// RETORNO FINAL (UM ÚNICO OBJETO JSON)\n// ==========================================\n\n// Junta as 3 listas, garantindo que os exatos venham primeiro, depois os com espaço/dois-pontos\nconst todosMatches = [...matchesExatos, ...matchesPrioritarios, ...matchesParciais];\n\n// Corta a lista de acordo com o limite configurado lá em cima\nconst topJogos = todosMatches.slice(0, limiteItens);\n\nif (topJogos.length > 0) {\n  // Retorna apenas 1 \"Item\" no n8n, contendo o array de jogos dentro dele\n  return [{ \n    json: { \n      termo_buscado: rawTargetName,\n      quantidade_retornada: topJogos.length,\n      jogos: topJogos \n    } \n  }];\n} else {\n  return [{ json: { erro: `Nenhum jogo encontrado contendo o nome: ${rawTargetName}` } }];\n}"
      },
