generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model User {
    id            String         @id @default(auto()) @map("_id") @db.ObjectId
    idPublic      String         @unique @default(uuid())
    name          String
    email         String         @unique
    password      String
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    img           String?
    banner        String?
    manuals       Manual[]
    rules         Rule[]
    questions     Question[]
    aiPosts       AIPost[]
    comments      Comment[]
    savedSnippets SavedSnippet[]

    following Follow[] @relation("FollowingRelation")
    followers Follow[] @relation("FollowersRelation")

    contributedManualIds String[] @db.ObjectId
    contributedManuals   Manual[] @relation("ManualContributors", fields: [contributedManualIds], references: [id])
}

model Manual {
    id          String  @id @default(auto()) @map("_id") @db.ObjectId
    idPublic    String  @unique @default(uuid())
    name        String
    game        String
    genre       String
    playTime    Int
    minPlayers  Int
    maxPlayers  Int
    description String
    ageRange    String
    edition     String
    type        String
    system      String?
    imgBanner   String?
    imgLogo     String?
    isOfficial  Boolean @default(false)

    contributorIds String[] @db.ObjectId
    contributors   User[]   @relation("ManualContributors", fields: [contributorIds], references: [id])

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id])

    clonedFromId String?  @db.ObjectId
    cloneHistory String[] @db.ObjectId

    ruleIds String[] @db.ObjectId
    rules   Rule[]   @relation(fields: [ruleIds], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Rule {
    id          String  @id @default(auto()) @map("_id") @db.ObjectId
    idPublic    String  @unique @default(uuid())
    name        String
    description String
    status      String  @default("PUBLICADO")
    likeCount   Int     @default(0)
    isHouseRule Boolean @default(false)

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id])

    manualIds String[] @db.ObjectId
    manuals   Manual[] @relation(fields: [manualIds], references: [id])

    originManualId String? @db.ObjectId
    overrideId     String? @db.ObjectId

    comments Comment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Question {
    id          String @id @default(auto()) @map("_id") @db.ObjectId
    idPublic    String @unique @default(uuid())
    name        String
    game        String
    description String
    likeCount   Int    @default(0)

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id])

    comments Comment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model AIPost {
    id         String  @id @default(auto()) @map("_id") @db.ObjectId
    idPublic   String  @unique @default(uuid())
    title      String?
    promptUser String
    aiResponse String
    likeCount  Int     @default(0)

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id])

    comments Comment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model SavedSnippet {
    id        String @id @default(auto()) @map("_id") @db.ObjectId
    savedText String

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id])

    createdAt DateTime @default(now())
}

model Comment {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    text      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    authorId String @db.ObjectId
    author   User   @relation(fields: [authorId], references: [id])

    ruleId String? @db.ObjectId
    rule   Rule?   @relation(fields: [ruleId], references: [id], onDelete: Cascade)

    questionId String?   @db.ObjectId
    question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)

    aiPostId String? @db.ObjectId
    aiPost   AIPost? @relation(fields: [aiPostId], references: [id], onDelete: Cascade)

    parentId String?   @db.ObjectId
    parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
    replies  Comment[] @relation("CommentReplies")
}

model Follow {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    followerId String @db.ObjectId
    follower   User   @relation("FollowingRelation", fields: [followerId], references: [id])

    followedId String @db.ObjectId
    followed   User   @relation("FollowersRelation", fields: [followedId], references: [id])

    createdAt DateTime @default(now())

    @@unique([followerId, followedId])
}
